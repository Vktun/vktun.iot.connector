<UserControl x:Class="Vktun.IoT.Connector.Client.Views.ModbusTcpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Padding="10">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <GroupBox Grid.Row="0" Header="连接配置" Style="{StaticResource CardGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Column="0" Text="IP地址:" Style="{StaticResource LabelTextBlock}"/>
                <TextBox Grid.Column="1" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource InputTextBox}" Width="120"/>
                
                <TextBlock Grid.Column="2" Text="端口:" Style="{StaticResource LabelTextBlock}"/>
                <TextBox Grid.Column="3" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource InputTextBox}" Width="80"/>
                
                <TextBlock Grid.Column="4" Text="从站ID:" Style="{StaticResource LabelTextBlock}"/>
                <TextBox Grid.Column="5" Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource InputTextBox}" Width="60"/>
                
                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button Content="连接" Command="{Binding ConnectCommand}"
                           Style="{StaticResource PrimaryButton}" Width="80"/>
                    <Button Content="断开" Command="{Binding DisconnectCommand}"
                           Style="{StaticResource SecondaryButton}" Width="80"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="1" Header="读写操作" Style="{StaticResource CardGroupBox}" Margin="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="寄存器类型:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding RegisterTypes}"
                         SelectedItem="{Binding SelectedRegisterType}"
                         Style="{StaticResource InputComboBox}" Width="120"/>
                
                <TextBlock Grid.Column="2" Text="地址:" Style="{StaticResource LabelTextBlock}"/>
                <TextBox Grid.Column="3" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource InputTextBox}" Width="80"/>
                
                <TextBlock Grid.Column="4" Text="数据类型:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Grid.Column="5" ItemsSource="{Binding DataTypes}"
                         SelectedItem="{Binding SelectedDataType}"
                         Style="{StaticResource InputComboBox}" Width="100"/>
                
                <TextBlock Grid.Column="6" Text="写入值:" Style="{StaticResource LabelTextBlock}"/>
                <TextBox Grid.Column="7" Text="{Binding WriteValue, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource InputTextBox}" Width="100"/>
                
                <StackPanel Grid.Column="8" Orientation="Horizontal">
                    <Button Content="读取" Command="{Binding ReadCommand}"
                           Style="{StaticResource PrimaryButton}" Width="80"/>
                    <Button Content="写入" Command="{Binding WriteCommand}"
                           Style="{StaticResource SecondaryButton}" Width="80"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="2" Header="批量测试" Style="{StaticResource CardGroupBox}" Margin="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <DataGrid Grid.Column="0" ItemsSource="{Binding TestDataList}"
                         Style="{StaticResource DataGridStyle}"
                         SelectedItem="{Binding SelectedTestData}"
                         Height="150">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="80"/>
                        <DataGridTextColumn Header="数据类型" Binding="{Binding DataType}" Width="100"/>
                        <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="100"/>
                        <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                        <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10,0,0,0">
                    <Button Content="添加" Command="{Binding AddTestDataCommand}"
                           Style="{StaticResource PrimaryButton}" Width="80"/>
                    <Button Content="删除" Command="{Binding RemoveTestDataCommand}"
                           Style="{StaticResource SecondaryButton}" Width="80"/>
                    <Button Content="批量读取" Command="{Binding BatchReadCommand}"
                           Style="{StaticResource PrimaryButton}" Width="80"/>
                    <Button Content="批量写入" Command="{Binding BatchWriteCommand}"
                           Style="{StaticResource SecondaryButton}" Width="80"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="3" Header="测试结果" Style="{StaticResource CardGroupBox}" Margin="10,0">
            <DataGrid ItemsSource="{Binding TestResults}"
                     Style="{StaticResource DataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="80"/>
                    <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="100"/>
                    <DataGridTextColumn Header="数据类型" Binding="{Binding DataType}" Width="80"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60"/>
                    <DataGridTextColumn Header="耗时(ms)" Binding="{Binding Duration}" Width="80"/>
                    <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="80"/>
                    <DataGridTextColumn Header="错误信息" Binding="{Binding ErrorMessage}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        
        <GroupBox Grid.Row="4" Header="通信日志" Style="{StaticResource CardGroupBox}" Margin="10,0,10,10">
            <TextBox Text="{Binding LogMessages}" IsReadOnly="True"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    TextWrapping="Wrap"
                    FontFamily="Consolas"
                    FontSize="12"
                    Background="#F5F5F5"
                    Height="100"/>
        </GroupBox>
    </Grid>
</UserControl>
