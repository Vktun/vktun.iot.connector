<UserControl x:Class="Vktun.IoT.Connector.Client.Views.SerialPortView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Padding="10">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <GroupBox Grid.Row="0" Header="串口配置" Style="{StaticResource CardGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="端口:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding PortNames}"
                         SelectedItem="{Binding SelectedPortName}"
                         Style="{StaticResource InputComboBox}" Width="80"/>
                
                <TextBlock Grid.Column="2" Text="波特率:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding BaudRates}"
                         SelectedItem="{Binding SelectedBaudRate}"
                         Style="{StaticResource InputComboBox}" Width="80"/>
                
                <TextBlock Grid.Column="4" Text="数据位:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Grid.Column="5" ItemsSource="{Binding DataBitsList}"
                         SelectedItem="{Binding SelectedDataBits}"
                         Style="{StaticResource InputComboBox}" Width="50"/>
                
                <TextBlock Grid.Column="6" Text="停止位:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Grid.Column="7" ItemsSource="{Binding StopBitsList}"
                         SelectedItem="{Binding SelectedStopBits}"
                         Style="{StaticResource InputComboBox}" Width="60"/>
                
                <TextBlock Grid.Column="8" Text="校验位:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Grid.Column="9" ItemsSource="{Binding ParityList}"
                         SelectedItem="{Binding SelectedParity}"
                         Style="{StaticResource InputComboBox}" Width="60"/>
                
                <StackPanel Grid.Column="10" Orientation="Horizontal">
                    <Button Content="打开" Command="{Binding OpenCommand}"
                           Style="{StaticResource PrimaryButton}" Width="80"/>
                    <Button Content="关闭" Command="{Binding CloseCommand}"
                           Style="{StaticResource SecondaryButton}" Width="80"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="1" Header="数据收发" Style="{StaticResource CardGroupBox}" Margin="10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <GroupBox Grid.Column="0" Header="接收数据" Margin="0,0,5,0">
                        <TextBox Text="{Binding ReceivedData}" IsReadOnly="True"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto"
                                TextWrapping="Wrap"
                                FontFamily="Consolas"
                                FontSize="12"
                                Background="#F5F5F5"/>
                    </GroupBox>
                    
                    <GroupBox Grid.Column="1" Header="发送数据" Margin="5,0,0,0">
                        <TextBox Text="{Binding SendData, UpdateSourceTrigger=PropertyChanged}"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto"
                                TextWrapping="Wrap"
                                FontFamily="Consolas"
                                FontSize="12"
                                AcceptsReturn="True"/>
                    </GroupBox>
                </Grid>
                
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <CheckBox Grid.Column="0" Content="十六进制显示"
                             IsChecked="{Binding IsHexDisplay}"
                             VerticalAlignment="Center" Margin="5"/>
                    
                    <CheckBox Grid.Column="1" Content="十六进制发送"
                             IsChecked="{Binding IsHexSend}"
                             VerticalAlignment="Center" Margin="5"/>
                    
                    <CheckBox Grid.Column="2" Content="自动发送"
                             IsChecked="{Binding IsAutoSend}"
                             VerticalAlignment="Center" Margin="5"/>
                    
                    <TextBlock Grid.Column="3" Text="间隔(ms):" 
                              Style="{StaticResource LabelTextBlock}"/>
                    <TextBox Grid.Column="4" Text="{Binding AutoSendInterval}"
                            Style="{StaticResource InputTextBox}" Width="60"/>
                    
                    <Button Grid.Column="5" Content="清空接收" 
                           Command="{Binding ClearReceivedCommand}"
                           Style="{StaticResource SecondaryButton}" Width="80"/>
                    
                    <Button Grid.Column="6" Content="发送" 
                           Command="{Binding SendCommand}"
                           Style="{StaticResource PrimaryButton}" Width="80"/>
                </Grid>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="2" Header="状态信息" Style="{StaticResource CardGroupBox}" Margin="10,0,10,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="接收:" Style="{StaticResource LabelTextBlock}"/>
                <TextBlock Grid.Column="1" Text="{Binding ReceivedCount, StringFormat='{}{0} 字节'}"
                          Style="{StaticResource LabelTextBlock}"/>
                
                <TextBlock Grid.Column="2" Text="发送:" Style="{StaticResource LabelTextBlock}"/>
                <TextBlock Grid.Column="3" Text="{Binding SentCount, StringFormat='{}{0} 字节'}"
                          Style="{StaticResource LabelTextBlock}"/>
                
                <TextBlock Grid.Column="4" Text="状态:" Style="{StaticResource LabelTextBlock}"/>
                <TextBlock Grid.Column="5" Text="{Binding Status}"
                          Style="{StaticResource LabelTextBlock}"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
