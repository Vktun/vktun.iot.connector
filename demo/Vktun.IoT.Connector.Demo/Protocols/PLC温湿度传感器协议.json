{
  "ProtocolId": "PLC_TemperatureHumidity_001",
  "ProtocolName": "PLC温湿度传感器协议",
  "Description": "Modbus TCP PLC 温湿度传感器协议配置模板，支持温度、湿度、露点温度等数据采集",
  "ModbusType": "Tcp",
  "SlaveId": 1,
  "ByteOrder": "BigEndian",
  "WordOrder": "HighWordFirst",
  "ResponseTimeout": 3000,
  "RetryCount": 3,
  "RetryDelay": 1000,
  "Points": [
    {
      "PointName": "温度",
      "RegisterType": "HoldingRegister",
      "Address": 0,
      "Quantity": 1,
      "DataType": "Int16",
      "Ratio": 0.1,
      "OffsetValue": 0,
      "Unit": "℃",
      "MinValue": -40,
      "MaxValue": 80,
      "IsReadOnly": true,
      "Description": "环境温度测量值，范围 -40℃ ~ 80℃",
      "ScanRate": 1000
    },
    {
      "PointName": "湿度",
      "RegisterType": "HoldingRegister",
      "Address": 1,
      "Quantity": 1,
      "DataType": "UInt16",
      "Ratio": 0.1,
      "OffsetValue": 0,
      "Unit": "%RH",
      "MinValue": 0,
      "MaxValue": 100,
      "IsReadOnly": true,
      "Description": "环境湿度测量值，范围 0% ~ 100%",
      "ScanRate": 1000
    },
    {
      "PointName": "露点温度",
      "RegisterType": "HoldingRegister",
      "Address": 2,
      "Quantity": 1,
      "DataType": "Int16",
      "Ratio": 0.1,
      "OffsetValue": 0,
      "Unit": "℃",
      "MinValue": -40,
      "MaxValue": 80,
      "IsReadOnly": true,
      "Description": "露点温度计算值",
      "ScanRate": 5000
    },
    {
      "PointName": "设备运行状态",
      "RegisterType": "Coil",
      "Address": 0,
      "Quantity": 1,
      "DataType": "UInt8",
      "Ratio": 1,
      "OffsetValue": 0,
      "Unit": "",
      "MinValue": 0,
      "MaxValue": 1,
      "IsReadOnly": true,
      "Description": "设备运行状态: 0=停止, 1=运行",
      "ScanRate": 2000
    },
    {
      "PointName": "报警状态",
      "RegisterType": "DiscreteInput",
      "Address": 0,
      "Quantity": 1,
      "DataType": "UInt8",
      "Ratio": 1,
      "OffsetValue": 0,
      "Unit": "",
      "MinValue": 0,
      "MaxValue": 1,
      "IsReadOnly": true,
      "Description": "报警状态: 0=正常, 1=报警",
      "ScanRate": 2000
    },
    {
      "PointName": "温度校准值",
      "RegisterType": "HoldingRegister",
      "Address": 10,
      "Quantity": 1,
      "DataType": "Int16",
      "Ratio": 0.1,
      "OffsetValue": 0,
      "Unit": "℃",
      "MinValue": -5,
      "MaxValue": 5,
      "IsReadOnly": false,
      "Description": "温度校准偏移值",
      "ScanRate": 10000
    },
    {
      "PointName": "湿度校准值",
      "RegisterType": "HoldingRegister",
      "Address": 11,
      "Quantity": 1,
      "DataType": "Int16",
      "Ratio": 0.1,
      "OffsetValue": 0,
      "Unit": "%RH",
      "MinValue": -5,
      "MaxValue": 5,
      "IsReadOnly": false,
      "Description": "湿度校准偏移值",
      "ScanRate": 10000
    },
    {
      "PointName": "温度上限报警",
      "RegisterType": "HoldingRegister",
      "Address": 20,
      "Quantity": 1,
      "DataType": "Int16",
      "Ratio": 0.1,
      "OffsetValue": 0,
      "Unit": "℃",
      "MinValue": 0,
      "MaxValue": 100,
      "IsReadOnly": false,
      "Description": "温度上限报警阈值",
      "ScanRate": 10000
    },
    {
      "PointName": "湿度上限报警",
      "RegisterType": "HoldingRegister",
      "Address": 21,
      "Quantity": 1,
      "DataType": "UInt16",
      "Ratio": 0.1,
      "OffsetValue": 0,
      "Unit": "%RH",
      "MinValue": 0,
      "MaxValue": 100,
      "IsReadOnly": false,
      "Description": "湿度上限报警阈值",
      "ScanRate": 10000
    }
  ]
}