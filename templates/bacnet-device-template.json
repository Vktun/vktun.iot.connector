{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BACnet Device Template",
  "description": "BACnet楼宇自动化设备配置模板",
  "protocolId": "bacnet-v1",
  "protocolName": "BACnet/IP",
  "protocolType": "Custom",
  "protocolVersion": "1.0.0",
  "vendor": "Generic",
  "deviceModel": "BACnet-Controller",
  "additionalSettings": {
    "DeviceId": 1234,
    "NetworkNumber": 0,
    "MacAddress": "",
    "Port": 47808,
    "MaxApduLength": 1476,
    "SegmentTimeout": 5000,
    "SegmentationSupported": true,
    "HeartbeatTimeout": 30000
  },
  "points": [
    {
      "pointName": "AI:1",
      "displayName": "Zone Temperature",
      "dataType": "Float",
      "unit": "°C",
      "objectType": "AnalogInput",
      "objectInstance": 1,
      "propertyId": 85,
      "subscribe": true,
      "covIncrement": 0.5,
      "minValue": 0,
      "maxValue": 50,
      "isReadOnly": true,
      "description": "区域温度传感器"
    },
    {
      "pointName": "AI:2",
      "displayName": "Outside Air Temperature",
      "dataType": "Float",
      "unit": "°C",
      "objectType": "AnalogInput",
      "objectInstance": 2,
      "propertyId": 85,
      "subscribe": true,
      "covIncrement": 1.0,
      "minValue": -40,
      "maxValue": 60,
      "isReadOnly": true,
      "description": "室外温度传感器"
    },
    {
      "pointName": "AO:1",
      "displayName": "Cooling Valve Position",
      "dataType": "Float",
      "unit": "%",
      "objectType": "AnalogOutput",
      "objectInstance": 1,
      "propertyId": 85,
      "subscribe": false,
      "minValue": 0,
      "maxValue": 100,
      "isReadOnly": false,
      "description": "冷却阀门开度控制"
    },
    {
      "pointName": "BI:1",
      "displayName": "Fan Status",
      "dataType": "Bool",
      "unit": "",
      "objectType": "BinaryInput",
      "objectInstance": 1,
      "propertyId": 85,
      "subscribe": true,
      "isReadOnly": true,
      "description": "风机运行状态"
    },
    {
      "pointName": "BO:1",
      "displayName": "Fan Command",
      "dataType": "Bool",
      "unit": "",
      "objectType": "BinaryOutput",
      "objectInstance": 1,
      "propertyId": 85,
      "subscribe": false,
      "isReadOnly": false,
      "description": "风机启停命令"
    },
    {
      "pointName": "AV:1",
      "displayName": "Setpoint",
      "dataType": "Float",
      "unit": "°C",
      "objectType": "AnalogValue",
      "objectInstance": 1,
      "propertyId": 85,
      "subscribe": false,
      "minValue": 18,
      "maxValue": 28,
      "isReadOnly": false,
      "description": "温度设定值"
    },
    {
      "pointName": "MSI:1",
      "displayName": "Mode Status",
      "dataType": "UInt8",
      "unit": "",
      "objectType": "MultiStateInput",
      "objectInstance": 1,
      "propertyId": 85,
      "subscribe": true,
      "isReadOnly": true,
      "stateText": ["Off", "Cooling", "Heating", "Auto"],
      "description": "运行模式状态"
    },
    {
      "pointName": "MSO:1",
      "displayName": "Mode Command",
      "dataType": "UInt8",
      "unit": "",
      "objectType": "MultiStateOutput",
      "objectInstance": 1,
      "propertyId": 85,
      "subscribe": false,
      "isReadOnly": false,
      "stateText": ["Off", "Cooling", "Heating", "Auto"],
      "description": "运行模式命令"
    }
  ],
  "parseRules": {
    "ObjectIdentifierFormat": "{ObjectType}:{ObjectInstance}",
    "ObjectTypeAbbreviations": {
      "AI": "AnalogInput",
      "AO": "AnalogOutput",
      "AV": "AnalogValue",
      "BI": "BinaryInput",
      "BO": "BinaryOutput",
      "BV": "BinaryValue",
      "MSI": "MultiStateInput",
      "MSO": "MultiStateOutput"
    },
    "DefaultPropertyId": 85,
    "COVSubscription": true
  }
}